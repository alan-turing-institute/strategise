FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm ci

# Copy the entire application
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Run Vite development server with host flag to allow external access
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
